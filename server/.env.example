# ── Required ──────────────────────────────────────────────
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/tripwise?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_string

# ── Optional: unlocks real Gemini AI chatbot (falls back to offline knowledge base if missing) ──
GEMINI_API_KEY=

# ── Optional: unlocks real live flight/train pricing (falls back to realistic simulated data if missing) ──
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# ── Optional: for future Google Sign-In (Phase 2) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Optional: for future Mobile OTP auth via Firebase/Twilio/MSG91 (Phase 2) ──
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
